<!-- Bootstrap 5 JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Navbar scroll effect
    window.addEventListener('scroll', () => {
        const nav = document.getElementById('mainNav');
        if (window.scrollY > 40) {
            nav.classList.add('shadow-sm');
            nav.style.background = '#fff';
        } else {
            nav.classList.remove('shadow-sm');
            nav.style.background = 'rgba(255,255,255,0.93)';
        }
    });

    // Close mobile nav after link click
    document.querySelectorAll('#navMenu .nav-link').forEach(link => {
        link.addEventListener('click', () => {
            const collapse = document.getElementById('navMenu');
            const bsCollapse = bootstrap.Collapse.getInstance(collapse);
            if (bsCollapse) bsCollapse.hide();
        });
    });

    document.getElementById('searchForm').addEventListener('submit', function (e) {
        e.preventDefault();
        const phone = document.getElementById('phoneInput').value.trim();
        const resultsSection = document.getElementById('resultsSection');
        const resultsContainer = document.getElementById('resultsContainer');
        const phoneDisplay = document.getElementById('resultPhone');
        
        if (!phone) return;
        
        phoneDisplay.textContent = phone;
        resultsSection.style.display = 'block';
        resultsContainer.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary"></div><p class="mt-2 text-muted fw-bold">جاري البحث...</p></div>';
        
        resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });

        fetch('@Url.Action("SearchByPhoneAjax", "Result")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: new URLSearchParams({ phone: phone })
        })
        .then(response => {
            if (!response.ok && response.status !== 400 && response.status !== 404) {
                throw new Error('Network response was not ok');
            }
            return response.text();
        })
        .then(html => {
            resultsContainer.innerHTML = html;
        })
        .catch(error => {
            console.error('Error:', error);
            resultsContainer.innerHTML = '<div class="alert alert-danger text-center">حدث خطأ أثناء محاولة الاتصال بالخادم. يرجى المحاولة لاحقاً.</div>';
        });
    });

    document.addEventListener('click', function(e) {
        // Handle "عرض الزيارات السابقة" (Show All Visits)
        const allVisitsBtn = e.target.closest('#loadAllVisitsBtn');
        if (allVisitsBtn) {
            e.preventDefault();
            const phone = allVisitsBtn.getAttribute('data-phone');
            const resultsContainer = document.getElementById('resultsContainer');
            
            resultsContainer.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary"></div><p class="mt-2 text-muted fw-bold">جاري تحميل الزيارات السابقة...</p></div>';
            
            fetch('@Url.Action("GetAllVisitsAjax", "Result")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ phone: phone })
            })
            .then(res => res.text())
            .then(html => resultsContainer.innerHTML = html)
            .catch(err => resultsContainer.innerHTML = '<div class="alert alert-danger text-center">حدث خطأ أثناء تحميل الزيارات السابقة.</div>');
        }

        // Handle "العودة لآخر تحليل" (Back to Latest Result)
        const latestResultBtn = e.target.closest('#loadLatestResultBtn');
        if (latestResultBtn) {
            e.preventDefault();
            const phone = latestResultBtn.getAttribute('data-phone');
            const resultsContainer = document.getElementById('resultsContainer');
            
            resultsContainer.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary"></div><p class="mt-2 text-muted fw-bold">جاري الرجوع لآخر تحليل...</p></div>';
            
            fetch('@Url.Action("SearchByPhoneAjax", "Result")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ phone: phone })
            })
            .then(res => res.text())
            .then(html => resultsContainer.innerHTML = html)
            .catch(err => resultsContainer.innerHTML = '<div class="alert alert-danger text-center">حدث خطأ أثناء الرجوع لآخر تحليل.</div>');
        }
    });

    // ==========================================
    // Home Visit Form Logic
    // ==========================================
    document.addEventListener('DOMContentLoaded', function () {
        const homeVisitForm = document.getElementById('homeVisitForm');
        if (!homeVisitForm) return;

        const nameInput = document.getElementById('userName');
        const phoneInput = document.getElementById('userPhone');
        const addressInput = document.getElementById('userAddress');
        const imageInput = document.getElementById('userImage');
        const previewContainer = document.getElementById('imagePreviewContainer');
        const imagePreview = document.getElementById('imagePreview');
        const submitBtn = document.getElementById('submitVisitBtn');
        const successMsg = document.getElementById('successVisitMsg');
        let hasImage = false;

        if (localStorage.getItem('user_name')) nameInput.value = localStorage.getItem('user_name');
        if (localStorage.getItem('user_phone')) phoneInput.value = localStorage.getItem('user_phone');
        if (localStorage.getItem('user_address')) addressInput.value = localStorage.getItem('user_address');

        imageInput.addEventListener('change', function () {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    imagePreview.src = e.target.result;
                    previewContainer.style.display = 'block';
                    document.querySelector('.file-upload-display div').textContent = file.name;
                }
                reader.readAsDataURL(file);
                hasImage = true;
            } else {
                previewContainer.style.display = 'none';
                document.querySelector('.file-upload-display div').textContent = 'اضغط هنا لاختيار صورة';
                hasImage = false;
            }
        });

        homeVisitForm.addEventListener('submit', async function (e) {
            e.preventDefault();
            
            let isValid = true;
            [nameInput, phoneInput, addressInput].forEach(input => {
                if (!input.value.trim()) {
                    input.classList.add('is-invalid');
                    isValid = false;
                } else {
                    input.classList.remove('is-invalid');
                    input.classList.add('is-valid');
                }
            });

            if (!isValid) return;

            localStorage.setItem('user_name', nameInput.value.trim());
            localStorage.setItem('user_phone', phoneInput.value.trim());
            localStorage.setItem('user_address', addressInput.value.trim());

            submitBtn.disabled = true;
            submitBtn.style.display = 'none';
            successMsg.style.display = 'block';

            let uploadedImageUrl = '';

            if (hasImage && imageInput.files[0]) {
                const formData = new FormData();
                formData.append('image', imageInput.files[0]);

                try {
                    successMsg.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> جاري رفع الصورة...';
                    
                    const response = await fetch('/api/HomeVisit/UploadRequest', {
                        method: 'POST',
                        body: formData
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        uploadedImageUrl = result.imageUrl;
                    } else {
                        throw new Error(result.message || 'فشل في رفع الصورة');
                    }
                } catch (error) {
                    console.error('Upload Error:', error);
                    alert('حدث خطأ أثناء رفع الصورة. سيتم إرسال الطلب بدون المرفقات أو حاول مجدداً.');
                }
            }

            const name = nameInput.value.trim();
            const phone = phoneInput.value.trim();
            const address = addressInput.value.trim();
            
            let message = `طلب زيارة منزلية\n\nالاسم: ${name}\nرقم الهاتف: ${phone}\nالعنوان: ${address}`;
            
            if (uploadedImageUrl) {
                message += `\n\nصورة التحليل:\n${uploadedImageUrl}`;
            }

            const encodedMessage = encodeURIComponent(message);
            const whatsappUrl = `https://wa.me/201143041240?text=${encodedMessage}`;

            successMsg.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> جاري تحويلك إلى واتساب...';

            setTimeout(() => {
                window.open(whatsappUrl, '_blank');
                
                setTimeout(() => {
                    submitBtn.disabled = false;
                    submitBtn.style.display = 'flex';
                    successMsg.style.display = 'none';
                    successMsg.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> جاري تحويلك إلى واتساب...';
                }, 3000);
            }, 800);
        });

        [nameInput, phoneInput, addressInput].forEach(input => {
            input.addEventListener('input', function() {
                this.classList.remove('is-invalid');
            });
        });
    });
</script>
</body>
</html>
