<!-- Bootstrap 5 JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Navbar scroll effect
    window.addEventListener('scroll', () => {
        const nav = document.getElementById('mainNav');
        if (window.scrollY > 40) {
            nav.classList.add('shadow-sm');
            nav.style.background = '#fff';
        } else {
            nav.classList.remove('shadow-sm');
            nav.style.background = 'rgba(255,255,255,0.93)';
        }
    });

    // Close mobile nav after link click
    document.querySelectorAll('#navMenu .nav-link').forEach(link => {
        link.addEventListener('click', () => {
            const collapse = document.getElementById('navMenu');
            const bsCollapse = bootstrap.Collapse.getInstance(collapse);
            if (bsCollapse) bsCollapse.hide();
        });
    });

    // Search button – load and render PDF
    pdfjsLib.GlobalWorkerOptions.workerSrc =
        'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

    document.getElementById('searchBtn').addEventListener('click', () => {
        const phone = document.getElementById('phoneInput').value.trim();
        if (!phone || phone.length < 10) {
            document.getElementById('phoneInput').classList.add('is-invalid');
            return;
        }
        document.getElementById('phoneInput').classList.remove('is-invalid');
        document.getElementById('resultPhone').textContent = phone;

        const resultsSection = document.getElementById('resultsSection');
        resultsSection.style.display = 'block';
        resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });

        // Reset viewer state
        document.getElementById('pdfLoading').style.display = 'block';
        document.getElementById('pdfError').style.display = 'none';
        document.getElementById('pdfPagesContainer').style.display = 'none';
        document.getElementById('pdfPages').innerHTML = '';

        // Load PDF from server
        const pdfUrl = '/pdfs/latest.pdf?t=' + Date.now(); // cache-bust
        pdfjsLib.getDocument(pdfUrl).promise
            .then(pdf => {
                document.getElementById('pdfLoading').style.display = 'none';
                document.getElementById('pdfPagesContainer').style.display = 'block';

                const container = document.getElementById('pdfPages');
                const totalPages = pdf.numPages;

                // Render each page as a canvas
                const renderPage = (pageNum) => {
                    pdf.getPage(pageNum).then(page => {
                        const scale = window.innerWidth < 600 ? 1.2 : 2.0;
                        const viewport = page.getViewport({ scale });

                        const canvas = document.createElement('canvas');
                        canvas.width  = viewport.width;
                        canvas.height = viewport.height;
                        canvas.style.width  = '100%';
                        canvas.style.borderRadius = '12px';
                        canvas.style.boxShadow = '0 4px 18px rgba(0,0,0,.12)';

                        container.appendChild(canvas);
                        page.render({ canvasContext: canvas.getContext('2d'), viewport });
                    });
                };

                for (let i = 1; i <= totalPages; i++) renderPage(i);
            })
            .catch(() => {
                document.getElementById('pdfLoading').style.display = 'none';
                document.getElementById('pdfError').style.display = 'block';
            });
    });
</script>
</body>
