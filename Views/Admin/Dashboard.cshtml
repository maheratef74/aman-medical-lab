@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-4">
    <div class="col-12">
        <h2 class="text-secondary border-bottom pb-2">مرحباً بك في لوحة تحكم الإدارة</h2>
        <p class="text-muted">من هنا يمكنك إدارة بيانات المرضى ورفع نتائج الفحوصات.</p>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card shadow border-0 border-start border-primary border-4">
            <div class="card-body py-4">
                <div class="d-flex align-items-center">
                    <div class="flex-grow-1">
                        <h5 class="text-primary fw-bold mb-1">المرضى</h5>
                        <p class="mb-0 text-muted">إدارة بيانات المرضى المسجلين</p>
                    </div>
                    <div class="text-primary bg-primary bg-opacity-10 p-3 rounded-circle">
                        <i class="fas fa-users fa-2x"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <a asp-controller="Patients" asp-action="Index" class="btn btn-sm btn-outline-primary">عرض المرضى &rarr;</a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-6 mb-4">
        <div class="card shadow border-0 border-start border-success border-4">
            <div class="card-body py-4">
                <div class="d-flex align-items-center">
                    <div class="flex-grow-1">
                        <h5 class="text-success fw-bold mb-1">إضافة مريض جديد</h5>
                        <p class="mb-0 text-muted">تسجيل بيانات مريض جديد لرفع النتائج</p>
                    </div>
                    <div class="text-success bg-success bg-opacity-10 p-3 rounded-circle">
                        <i class="fas fa-user-plus fa-2x"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <a asp-controller="Patients" asp-action="Create" class="btn btn-sm btn-outline-success">إضافة الآن &rarr;</a>
                </div>
            </div>
        </div>
    </div>
</div>
